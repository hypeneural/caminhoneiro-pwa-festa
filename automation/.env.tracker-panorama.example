# Exemplo sem segredos para o tracker e o panorama.
# Copie apenas as linhas necessárias para automation/.env.

# Integração existente com a Z-API
ZAPI_INSTANCE_ID=
ZAPI_TOKEN=
ZAPI_CLIENT_TOKEN=
TRACKER_NOTIFY_PHONE=55DDDNUMERO
# Somente offline do rastreador e recuperacao; vazio usa o destino principal.
TRACKER_SYSTEM_ALERT_PHONE=120363000000000000-group

# Origem e persistência do tracker
TRACKER_ENDPOINT=https://live.evydencia.com/public/state
TRACKER_POLL_SECONDS=5
TRACKER_SQLITE_PATH=data/tracker_state.db
TRACKER_LEADER_LEASE_SECONDS=120
NOMINATIM_USER_AGENT=festadoscaminhoneiros-tracker/1.0

# Canais independentes e persistentes de texto/localização
TRACKER_NOTIFICATION_MAX_ATTEMPTS=5
TRACKER_NOTIFICATION_LEASE_SECONDS=45
TRACKER_NOTIFICATION_TEXT_TTL_SECONDS=300
TRACKER_NOTIFICATION_LOCATION_TTL_SECONDS=180
TRACKER_NOTIFICATION_POLL_SECONDS=0.25
# Envia 3 mensagens separadas contendo apenas "." ao final de cada fluxo.
TRACKER_COMPLETION_SEPARATOR_COUNT=3
TRACKER_LOCATION_MAX_ACCURACY_M=100

# Geocodificação fora do polling principal
TRACKER_GEOCODER_CACHE_TTL_SECONDS=21600
TRACKER_GEOCODER_CACHE_DISTANCE_M=150
TRACKER_GEOCODER_STALE_CACHE_TTL_SECONDS=604800
TRACKER_GEOCODER_STALE_CACHE_DISTANCE_M=150
TRACKER_GEOCODER_JOB_MAX_AGE_SECONDS=120
TRACKER_GEOCODER_MAX_ATTEMPTS=3
TRACKER_GEOCODER_RETRY_BASE_SECONDS=0.25

# Panorama sem API oficial paga
TRACKER_PANORAMA_ENABLED=true
TRACKER_COMBINED_MESSAGE_ENABLED=true
TRACKER_PANORAMA_CAPTION_MAX_CHARS=900
TRACKER_PANORAMA_HEADLESS=true

# Vazios: descoberta automática do navegador e resolução pelo Selenium Manager.
# Em produção, caminhos explícitos tornam a inicialização mais previsível.
TRACKER_CHROME_BINARY=
TRACKER_CHROMEDRIVER_PATH=

TRACKER_PANORAMA_WINDOW_WIDTH=1280
TRACKER_PANORAMA_WINDOW_HEIGHT=720
TRACKER_PANORAMA_PAGE_TIMEOUT_SECONDS=25.0
TRACKER_PANORAMA_SETTLE_SECONDS=2.5
TRACKER_PANORAMA_RETRIES=1
TRACKER_PANORAMA_USE_SWIFTSHADER=true

# Mantenha false. Use true somente em contêiner/ambiente isolado se necessário.
TRACKER_PANORAMA_NO_SANDBOX=false

TRACKER_PANORAMA_MAX_JPEG_BYTES=2000000
TRACKER_PANORAMA_RETRY_COOLDOWN_MINUTES=5
TRACKER_PANORAMA_NO_IMAGERY_COOLDOWN_MINUTES=360
TRACKER_PANORAMA_NO_IMAGERY_RETRY_DISTANCE_M=500
TRACKER_PANORAMA_STREET_CHANGE_MIN_DISTANCE_M=60
TRACKER_PANORAMA_MAX_FIX_AGE_SECONDS=120
TRACKER_PANORAMA_FUTURE_TOLERANCE_SECONDS=30
TRACKER_PANORAMA_MAX_ACCURACY_M=75
TRACKER_PANORAMA_JOB_MAX_AGE_SECONDS=120
TRACKER_PANORAMA_SEND_ATTEMPTS=3
